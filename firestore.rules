rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function memberPath(communityId, uid) {
      return /databases/$(database)/documents/communityMembers/$(communityId + '_' + uid);
    }

    function isCommunityActiveMember(communityId) {
      return signedIn()
        && exists(memberPath(communityId, request.auth.uid))
        && get(memberPath(communityId, request.auth.uid)).data.status == 'active';
    }

    function isCommunityManager(communityId) {
      return isAdmin()
        || (
          signedIn()
          && exists(memberPath(communityId, request.auth.uid))
          && get(memberPath(communityId, request.auth.uid)).data.status == 'active'
          && (
            get(memberPath(communityId, request.auth.uid)).data.role == 'owner'
            || get(memberPath(communityId, request.auth.uid)).data.role == 'admin'
          )
        );
    }

    // Topluluk sayaçlarının negatife düşmemesini kontrol eder
    function hasNonNegativeCounters() {
      let d = request.resource.data;
      return (!('memberCount' in d) || (d.memberCount is number && d.memberCount >= 0))
        && (!('postCount' in d) || (d.postCount is number && d.postCount >= 0))
        && (!('messageCount' in d) || (d.messageCount is number && d.messageCount >= 0))
        && (!('requestCount' in d) || (d.requestCount is number && d.requestCount >= 0));
    }

    // Yeni topluluk oluşturulurken tüm sayaçların bulunmasını zorunlu tutar
    function hasAllCommunityCounters() {
      let d = request.resource.data;
      return d.memberCount is number && d.memberCount >= 0
        && d.postCount is number && d.postCount >= 0
        && d.messageCount is number && d.messageCount >= 0
        && d.requestCount is number && d.requestCount >= 0;
    }

    function hasSmallCounterDelta(afterValue, beforeValue) {
      return afterValue >= beforeValue - 1
        && afterValue <= beforeValue + 1;
    }

    // Sadece mevcut sayaç alanları değiştirilmişse delta kontrolü yap
    function hasBoundedCounterChanges() {
      let d = request.resource.data;
      let r = resource.data;
      return (!('memberCount' in d) || hasSmallCounterDelta(d.memberCount, r.get('memberCount', 0)))
        && (!('postCount' in d) || hasSmallCounterDelta(d.postCount, r.get('postCount', 0)))
        && (!('messageCount' in d) || hasSmallCounterDelta(d.messageCount, r.get('messageCount', 0)))
        && (!('requestCount' in d) || hasSmallCounterDelta(d.requestCount, r.get('requestCount', 0)));
    }

    // Bilinen reaksiyon anahtarları — communityService.js ile eşleştirildi
    function hasKnownReactions() {
      return request.resource.data.reactions is map
        && request.resource.data.reactions.keys().hasOnly(
            ['heart', 'fire', 'coffee', 'laugh', 'wave', 'pin', 'book', 'game']
           );
    }

    function isDefaultCommunityId(communityId) {
      return communityId in ['espor', 'yazilim', 'kahve', 'study', 'fotograf', 'muzik'];
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn();

      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 48
        && request.resource.data.avatarId is string
        && request.resource.data.avatarId.size() <= 24
        && request.resource.data.department is string
        && request.resource.data.department.size() <= 48
        && request.resource.data.bio is string
        && request.resource.data.bio.size() <= 120
        && request.resource.data.searchName is string
        && request.resource.data.searchName.size() <= 48;

      allow delete: if isOwner(userId);
    }

    match /publicLeaderboard/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.totalScore is number
        && request.resource.data.totalScore >= 0
        && request.resource.data.totalScore <= 1000000
        && request.resource.data.quizScore is number
        && request.resource.data.quizScore >= 0
        && request.resource.data.quizScore <= 1000000
        && request.resource.data.gameScore is number
        && request.resource.data.gameScore >= 0
        && request.resource.data.gameScore <= 1000000
        && request.resource.data.socialScore is number
        && request.resource.data.socialScore >= 0
        && request.resource.data.socialScore <= 1000000;
      allow delete: if false;
    }

    match /quizSets/{quizId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /gameConfigs/{configId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /pomodoroRooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.code == roomId;
      allow update: if signedIn()
        && resource.data.code == roomId;
      allow delete: if false;
    }

    match /communities/{communityId} {
      allow read: if signedIn();

      // Yeni topluluk oluşturma
      allow create: if signedIn()
        && request.resource.data.id == communityId
        && (
          request.resource.data.ownerUid == request.auth.uid
          || (isDefaultCommunityId(communityId) && request.resource.data.ownerUid == 'system')
        )
        && request.resource.data.name is string
        && request.resource.data.emoji is string
        && request.resource.data.category is string
        && request.resource.data.visibility in ['public', 'private']
        && request.resource.data.joinPolicy in ['open', 'approval']
        && hasAllCommunityCounters();

      // Topluluk güncelleme — 4 senaryo:
      // 1) Yönetici/sahip topluluk bilgilerini değiştiriyor
      // 2) Aktif üye post/mesaj sayaçlarını değiştiriyor
      // 3) Herhangi bir üye katılıp/ayrılırken üye sayaçlarını değiştiriyor
      // 4) ensureDefaultCommunities: sistem alanlarını merge ile senkronize ediyor
      allow update: if signedIn()
        && hasNonNegativeCounters()
        && (
          isCommunityManager(communityId)
          || (
            isCommunityActiveMember(communityId)
            && hasBoundedCounterChanges()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['postCount', 'messageCount', 'updatedAt'])
          )
          || (
            hasBoundedCounterChanges()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['memberCount', 'requestCount', 'updatedAt'])
          )
          || (
            isDefaultCommunityId(communityId)
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['name', 'emoji', 'category', 'about', 'prompt',
                          'tags', 'color', 'cover', 'visibility', 'joinPolicy',
                          'ownerUid', 'ownerName', 'updatedAt'])
          )
        );

      allow delete: if isAdmin();
    }

    match /communityMembers/{memberId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.communityId is string
        && request.resource.data.communityName is string
        && request.resource.data.displayName is string
        && request.resource.data.status in ['active', 'pending', 'banned']
        && request.resource.data.role in ['owner', 'admin', 'member']
        && memberId == request.resource.data.communityId + '_' + request.auth.uid;

      allow update: if signedIn()
        && resource.data.communityId is string
        && (
          resource.data.uid == request.auth.uid
          || isCommunityManager(resource.data.communityId)
        )
        && request.resource.data.status in ['active', 'pending', 'banned']
        && request.resource.data.role in ['owner', 'admin', 'member'];

      allow delete: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || isCommunityManager(resource.data.communityId)
        );
    }

    match /communityPosts/{postId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.communityId is string
        && isCommunityActiveMember(request.resource.data.communityId)
        && request.resource.data.authorName is string
        && request.resource.data.reactions is map
        && request.resource.data.text is string
        && request.resource.data.text.size() > 1
        && request.resource.data.text.size() <= 280;

      allow update: if signedIn()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.communityId == resource.data.communityId
        && (
          // Kendi gönderisini düzenliyor
          (
            resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'editedAt', 'updatedAt'])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 1
            && request.resource.data.text.size() <= 280
          )
          // Reaksiyon güncelliyor
          || (
            isCommunityActiveMember(resource.data.communityId)
            && hasKnownReactions()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['reactions', 'updatedAt'])
          )
          // Yorum sayacı güncelliyor
          || (
            isCommunityActiveMember(resource.data.communityId)
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['commentCount', 'updatedAt'])
            && request.resource.data.commentCount is number
            && request.resource.data.commentCount >= 0
          )
          // Yönetici silme/düzenleme
          || isCommunityManager(resource.data.communityId)
        );

      allow delete: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || isCommunityManager(resource.data.communityId)
        );
    }

    match /communityPostComments/{commentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.communityId is string
        && request.resource.data.postId is string
        && isCommunityActiveMember(request.resource.data.communityId)
        && request.resource.data.authorName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180;

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.communityId == resource.data.communityId
        && request.resource.data.postId == resource.data.postId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['text', 'editedAt', 'updatedAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180;

      allow delete: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || isCommunityManager(resource.data.communityId)
        );
    }

    match /communityMessages/{messageId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.communityId is string
        && isCommunityActiveMember(request.resource.data.communityId)
        && request.resource.data.authorName is string
        && request.resource.data.reactions is map
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180;

      allow update: if signedIn()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.communityId == resource.data.communityId
        && (
          // Kendi mesajını düzenliyor
          (
            resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'editedAt', 'updatedAt'])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 180
          )
          // Reaksiyon güncelliyor
          || (
            isCommunityActiveMember(resource.data.communityId)
            && hasKnownReactions()
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['reactions', 'updatedAt'])
          )
        );

      allow delete: if signedIn()
        && (
          resource.data.uid == request.auth.uid
          || isCommunityManager(resource.data.communityId)
        );
    }

    match /campusSpots/{spotId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.authorName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 1
        && request.resource.data.text.size() <= 280
        && request.resource.data.location is string
        && request.resource.data.location in [
             'Söylemek istemiyorum', 'Kampüs', 'Kafeterya',
             'Kütüphane', 'BM Fakültesi', 'Amfi', 'Bahçe'
           ]
        && request.resource.data.type is string
        && request.resource.data.type in ['study', 'coffee', 'duo', 'quiz', 'event', 'game']
        && request.resource.data.reactions is map;

      allow update: if signedIn()
        && request.resource.data.uid == resource.data.uid
        && (
          (
            resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'editedAt', 'deleted', 'deletedAt', 'updatedAt'])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 1
            && request.resource.data.text.size() <= 280
          )
          || (
            request.resource.data.reactions is map
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['reactions', 'updatedAt'])
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['commentCount', 'updatedAt'])
            && request.resource.data.commentCount is number
            && request.resource.data.commentCount >= 0
          )
          || (
            resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['deleted', 'deletedAt', 'updatedAt'])
          )
        );

      allow delete: if false;
    }

    match /campusSpotComments/{commentId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.spotId is string
        && request.resource.data.authorName is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 180;

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.spotId == resource.data.spotId
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'editedAt', 'updatedAt'])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 180
          )
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['deleted', 'deletedAt', 'updatedAt'])
        );

      allow delete: if false;
    }

    // Diğer tüm belgelere erişimi engelle
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
